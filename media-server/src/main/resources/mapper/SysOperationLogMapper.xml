<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.connor.newsplatform.server.mapper.SysOperationLogMapper">

    <!-- 分页查询操作日志（动态SQL，支持操作类型模糊搜索和时间范围筛选） -->
    <select id="pageQuery" resultType="SysOperationLog">
        select * from sys_operation_log
        <where>
            <if test="operation != null and operation != ''">
                and operation like concat('%', #{operation}, '%')
            </if>
            <if test="beginTime != null">
                and create_time &gt;= #{beginTime}
            </if>
            <if test="endTime != null">
                and create_time &lt;= #{endTime}
            </if>
        </where>
        order by create_time desc
    </select>

</mapper>
